# ============================================================
# SHERLOCKED ERP — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_PASSWORD=your_db_password
DATABASE_URL=postgresql://postgres:your_db_password@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# --- PAYPLUS (Israeli payment processor) ---
# ⚠️ ONLY PayPlus — NEVER Stripe
PAYPLUS_API_KEY=your_payplus_api_key
PAYPLUS_SECRET_KEY=your_payplus_secret_key
PAYPLUS_TERMINAL_NUMBER=your_terminal_number
PAYPLUS_WEBHOOK_SECRET=your_webhook_secret
NEXT_PUBLIC_PAYPLUS_BASE_URL=https://restapidev.payplus.co.il
# Production: https://restapi.payplus.co.il

# --- EVOLUTION API (WhatsApp) ---
EVOLUTION_API_URL=https://your-evolution-api.railway.app
EVOLUTION_API_KEY=your_strong_api_key
EVOLUTION_INSTANCE_NAME=sherlocked-main

# --- MORNING (Green Invoice) ---
MORNING_API_KEY=your_morning_api_key
MORNING_COMPANY_ID=your_company_id
MORNING_BASE_URL=https://api.greeninvoice.co.il/api/v1

# --- REDIS (Railway) ---
REDIS_URL=redis://default:password@your-redis.railway.app:6379

# --- APP URLS ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- AUTH ---
JWT_SECRET=your_very_long_random_jwt_secret_here

# --- VENUE ATTENDANCE (location-based check-in) ---
# GPS coordinates of the venue entrance
VENUE_LAT=32.0853
VENUE_LNG=34.7818
# Max allowed distance from venue in meters (default: 150)
VENUE_RADIUS_METERS=150
# Static public IP of the venue (optional — allows clock-in from venue network without GPS)
VENUE_STATIC_IP=

# --- RAILWAY ---
RAILWAY_TOKEN=your_railway_api_token
PORT=3001
